{
  "name": "aifight-desktop",
  "private": true,
  "version": "0.1.0-beta.13",
  "description": "AIFight desktop — a GUI over the AIFight bridge with live, full-information game rendering.",
  "author": "AIFight",
  "type": "module",
  "main": "dist/main/main.cjs",
  "scripts": {
    "dev": "vite",
    "build:renderer": "vite build",
    "build:main": "node esbuild.main.mjs",
    "build": "npm run build:renderer && npm run build:main",
    "start": "electron .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "package": "npm run build && electron-builder --publish never",
    "package:dir": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@aifight/aifight": "*",
    "@aifight/api-types": "*",
    "@aifight/ui": "*",
    "@napi-rs/keyring": "1.2.0",
    "better-sqlite3": "12.9.0",
    "electron-updater": "^6.8.3",
    "ws": "8.20.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "33.4.11",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.24.0",
    "i18next": "^25.8.14",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.6",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.4.2",
    "vitest": "^2.1.8"
  }
}
