{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    // Off because the renderer reuses the website's game-visual source
    // (../web/src/**) whose own tsconfig does not enforce it; we don't want
    // the website's style to fail the desktop build.
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": "."
  },
  "include": ["src/renderer"]
}
